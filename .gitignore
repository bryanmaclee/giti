# giti: per-machine remote config (names + URLs + scope); never push.
.giti/remotes.json

# Note: .giti/private (the path manifest) is intentionally NOT ignored.
# It rides the _private bookmark per spec §12.2. The save-routing in
# src/private/save-routing.js ensures saves that only touch this file go
# on _private; sync's push filter keeps _private off public remotes.
